# ── Serveur de tokens LiveKit ─────────────────────────────────────────────────
# Copiez ce fichier vers /opt/livekit-token-server/.env
# Permissions obligatoires : chmod 600 /opt/livekit-token-server/.env

# Clé API LiveKit (depuis votre dashboard LiveKit Cloud ou serveur auto-hébergé)
LIVEKIT_API_KEY=your_livekit_api_key

# Secret LiveKit (depuis votre dashboard LiveKit Cloud ou serveur auto-hébergé)
LIVEKIT_API_SECRET=your_livekit_api_secret

# URL WebSocket de votre serveur LiveKit
LIVEKIT_URL=wss://livekit.votre-domaine.com

# URL de votre serveur Matrix (homeserver)
MATRIX_HOMESERVER=https://matrix.votre-domaine.com

# Port d'écoute (interne — ne pas exposer directement, proxifié par Nginx)
PORT=3001
